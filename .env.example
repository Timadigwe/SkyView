# === Backend ===
SOLANA_RPC_URL=https://api.devnet.solana.com

OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o
# Optional: smaller / faster model for guardrails (defaults to OPENROUTER_MODEL)
# GUARDRAIL_MODEL=openai/gpt-4o-mini
# CHAT_MAX_TOOL_ROUNDS=12

USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPZmZWeQ5s
POLL_INTERVAL_SEC=35

# Optional: absolute path to solana-mcp-minimal/build/index.js (default: walk from repo)
# MCP_ENTRY=

# === Frontend ===
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# === Optional: S3 chat memory (when the API runs in AWS) ===
# USE_S3=true
# S3_BUCKET=<from terraform output s3_chat_memory_bucket>
# PERSIST_CONVERSATIONS=true
# AWS_REGION matches the bucket region; credentials come from the task/instance role